import telebot # Импорт библиотеки телеграм-бота
import schedule # Импорт библиотеки для создания расписания
import time # Импорт библиотеки для синхронизации с часовым поясом
from threading import Thread # Библиотека для проверки времени
from telebot import types # Библиотека для создания клавиатуры с кнопками

API_TOKEN = '[ДАННЫЕ УДАЛЕНЫ]' # Токен бота
bot = telebot.TeleBot(API_TOKEN)

# Словарь для хранения напоминаний по chat_id
reminders = {}

# Проверка корректности времени по формату "ЧЧ:ММ"
def is_valid_time(time_str):
    if len(time_str) != 5 or time_str[2] != ':':
        return False # Возвращение значения, если формат времени неверный
    try:
        hours, minutes = time_str.split(':')
        hours = int(hours)
        minutes = int(minutes)
        return 0 <= hours <= 23 and 0 <= minutes <= 59
    except ValueError:
        return False # Возвращение значения, если часы больше 24 или меньше 0 и если минуты больше 59 и меньше 0 соответственно

# Отправка напоминания пользователю и удаление задачи из расписания.
def send_reminder(chat_id, text, job_id):
    bot.send_message(chat_id, f'Вам пришло напоминание: {text}')
    # Удаление задачи из бота
    schedule.cancel_job(job_id)
    # Очищение отправленных напоминаний из бота
    if chat_id in reminders:
        reminders[chat_id] = [r for r in reminders[chat_id] if r['text'] != text]

# Добавление напоминания в расписание
def schedule_reminder(chat_id, text, reminder_time):
    if chat_id not in reminders:
        reminders[chat_id] = []
    reminders[chat_id].append({'text': text, 'time': reminder_time})

    # Настройка расписания
    job = schedule.every().day.at(reminder_time).do(
        send_reminder, chat_id, text, schedule.default_scheduler.jobs[-1]
    )
    bot.send_message(chat_id, f'Созданное Вами напоминание установлено на {reminder_time}.')

# Удаление напоминания
def remove_reminder(chat_id, reminder_time):
    if chat_id in reminders:
        # Удаление напоминание из бота
        reminders[chat_id] = [r for r in reminders[chat_id] if r['time'] != reminder_time]
        # Нахождение и удаление напоминания из бота (если оно есть)
        for job in schedule.default_scheduler.jobs:
            if job.next_run.strftime('%H:%M') == reminder_time:
                schedule.cancel_job(job)
        bot.send_message(chat_id, f'Созданное Вами напоминание на {reminder_time} было успешно удалено.')
    # Если пользователь не создавал напоминаний
    else:
        bot.send_message(chat_id, 'Ваших напоминаний не найдено.')

# Если пользователь запустил бота, он может выбрать 3 действия по соответствующим кнопкам
@bot.message_handler(commands=['start'])
def start(message):
    keyboard = types.ReplyKeyboardMarkup(resize_keyboard=True)
    button1 = types.KeyboardButton('Создать напоминание')
    button2 = types.KeyboardButton('Посмотреть расписание')
    button3 = types.KeyboardButton('Удалить напоминание')
    keyboard.add(button1, button2, button3)
    bot.send_message(message.chat.id, 'Приветствую вас. Я - бот, который поможет Вам создать собственное расписание из напоминаний по конкретному времени. Выберите одно из трёх действий (если вы впервые пользуйтесь мною, то выберите "Создать напоминание") и мы приступим к работе:', reply_markup=keyboard)

# Если пользователь принял решение создать напоминание (расписание)
@bot.message_handler(func=lambda message: message.text == 'Создать напоминание')
def set_reminder(message):
    try:
        msg = bot.send_message(message.chat.id, 'Сперва-наперво, введите время вашего напоминания в формате "ЧЧ:ММ" (к примеру "12:00" без кавычек):')
        bot.register_next_step_handler(msg, get_time)
    except Exception as e:
        bot.reply_to(message, f'Возникла ошибка: {e}')

def get_time(message):
    reminder_time = message.text.strip()
    # Проверка формата времени
    if not is_valid_time(reminder_time):
        bot.send_message(
            message.chat.id,
            'Введённый Вами формат времени неверный. Используйте временной формат "ЧЧ:ММ" (например "12:00" без кавычек).'
        )
        return
    msg = bot.send_message(message.chat.id, 'Теперь, введите задачу, которую я мог бы вам напомнить в это время (например "Помыть посуду" без кавычек):') # Если пользователь верно ввёл формат, то он может задать напоминание для себя
    bot.register_next_step_handler(msg, get_text, reminder_time)

def get_text(message, reminder_time):
    reminder_text = message.text
    chat_id = message.chat.id
    schedule_reminder(chat_id, reminder_text, reminder_time)
    bot.send_message(chat_id, 'Напоминание успешно создано (посмотреть своё напоминание можно в расписании).')

# Если пользователь решил просмотреть расписание
@bot.message_handler(func=lambda message: message.text == 'Посмотреть расписание')
def show_schedule(message):
    chat_id = message.chat.id
    if chat_id in reminders and reminders[chat_id]:
        # Список напоминаний
        schedule_list = '\n'.join([f'{r["time"]} — {r["text"]}' for r in reminders[chat_id]])
        bot.send_message(chat_id, f'Ваше текущее расписание:\n{schedule_list}')
    # Если пользователь не создал напоминаний или удалил их ранее    
    else:
        bot.send_message(chat_id, 'На данный момент, у вас отсутствуют напоминания.')

# Если пользователь решил удалить созданные им напоминания
@bot.message_handler(func=lambda message: message.text == 'Удалить напоминание')
def remove_reminder_step(message):
    msg = bot.send_message(message.chat.id, 'Введите время напоминания, которое Вы желаете удалить в формате "ЧЧ:ММ" (к примеру "12:00" без кавычек):')
    bot.register_next_step_handler(msg, remove_reminder_by_time)

def remove_reminder_by_time(message):
    reminder_time = message.text.strip()
    # Проверка верности временного формата
    if not is_valid_time(reminder_time):
        bot.send_message(
            message.chat.id,
            'Введённый Вами формат времени неверный. Используйте временной формат "ЧЧ:ММ" (например "12:00" без кавычек). Если вы забыли время напоминания, то просмотрите его в расписании.'
        )
        return
    remove_reminder(message.chat.id, reminder_time)

# Проверка и выполнение запланированных напоминаний
def schedule_checker():
    while True:
        schedule.run_pending()
        time.sleep(1)

# Задавание проверки расписания
def run_schedule():
    Thread(target=schedule_checker, daemon=True).start()

# Окончательный запуск проверки расписания и бота
run_schedule()
bot.infinity_polling() # Бесконечный цикл ожидания новых сообщений
